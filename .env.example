# ── DeepSQL Self-Hosted — Environment Variables ────────────────────────────────
# install.sh copies this file to .env and fills in per-install values.
#
# Deployment model:
# - DeepSQL, Postgres, Valkey, pgvector, and the customer DB connections run
#   inside the customer environment.
# - Azure OpenAI stays DeepSQL-managed so usage can be metered and answer quality
#   can be monitored centrally.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Release Images
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Public GitHub Container Registry images. No docker login is required.
DEEPSQL_BACKEND_IMAGE=ghcr.io/deepsqlai/deepsql-self-host-backend:latest
DEEPSQL_FRONTEND_IMAGE=ghcr.io/deepsqlai/deepsql-self-host-frontend:latest

# Set to true only when the images were already loaded locally via `docker load`.
DEEPSQL_SKIP_IMAGE_PULL=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Security
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT signing secret — generate with: openssl rand -base64 64
SECURITY_JWT_SECRET=change-me-generate-with-openssl-rand-base64-64

# AES-GCM encryption key for stored DB credentials — generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32
ENCRYPTION_KEY_ID=self-hosted-key-1

# Vault database password. install.sh replaces this on first run.
DB_PASSWORD=change-me-generate-with-openssl-rand-base64-16

# Self-host should always use the hardened production Spring profile.
SPRING_PROFILES_ACTIVE=prod

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DeepSQL-Managed AI / LLM
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Azure OpenAI key and endpoint are sensitive and are prompted by install.sh.
AZURE_OPENAI_KEY=replace-with-deepsql-managed-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://replace-with-deepsql-managed-endpoint.cognitiveservices.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_CODEX_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_USE_RESPONSES_API=true
AZURE_OPENAI_RESPONSES_API_VERSION=2025-04-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_TIMEOUT_SECONDS=20
AZURE_OPENAI_EMBEDDING_FAIL_OPEN=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Vector Store
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Self-host installs always use local PostgreSQL + pgvector for RAG storage.
VECTOR_STORE_TYPE=pgvector
AZURE_SEARCH_ENABLED=false
SPRING_AUTOCONFIGURE_EXCLUDE=org.springframework.ai.vectorstore.azure.autoconfigure.AzureVectorStoreAutoConfiguration

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Frontend
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Host ports (change these only if the defaults are already in use)
DEEPSQL_FRONTEND_PORT=3000
DEEPSQL_BACKEND_PORT=8080
DEEPSQL_POSTGRES_PORT=5432
DEEPSQL_VALKEY_PORT=6379

# Browser origins allowed to call the backend
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Optional — Email Notifications
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USERNAME=your-email@gmail.com
#EMAIL_PASSWORD=your-app-password
#EMAIL_FROM=noreply@yourcompany.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Optional — Slack Data Agent (Socket Mode)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Slack bot runs inside the DeepSQL backend and connects outbound via Socket Mode.
# Recommended setup: create a dedicated non-admin DeepSQL user that owns only the
# connections Slack should be allowed to use, then set that username below.
SLACK_ENABLED=false
SLACK_SOCKET_MODE_ENABLED=false
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEEPSQL_BOT_USERNAME=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Admin Bootstrap (first-run only)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# install.sh prompts for the initial admin email/password and disables bootstrap
# after the account is created.
SECURITY_ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_SECRET=replace-with-a-one-time-bootstrap-secret
DEEPSQL_INITIAL_ADMIN_EMAIL=admin@yourcompany.com
DEEPSQL_INITIAL_ADMIN_PASSWORD=
